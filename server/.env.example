# Shubhmay server — copy to .env (never commit .env).
# Prefer configuring Supabase, Razorpay, and maps keys in Admin → Settings
# (stored encrypted under server/data/). Env vars still override when set.

# --- Server ---
PORT=3000
NODE_ENV=production

# Optional: 64 hex chars — pins encryption for server/data/runtime-settings.enc.json
# CONFIG_ENCRYPTION_KEY=

# Optional: legacy automation — X-Admin-Secret header (session cookie is primary)
# ADMIN_SECRET=

# --- Static site (typical VPS) ---
SERVE_STATIC=1
# STATIC_ROOT=/var/www/shubhmay

# --- Fallback only if not set in Admin (bootstrap fills encrypted store) ---
# SUPABASE_URL=
# SUPABASE_SERVICE_ROLE_KEY=
# SUPABASE_ANON_KEY=
# SUPABASE_SCHEMA=v2
# RAZORPAY_KEY_ID=
# RAZORPAY_KEY_SECRET=
# RAZORPAY_WEBHOOK_SECRET=
# KUNDLI_AMOUNT_PAISE=49900
# CURRENCY=INR
# GOOGLE_MAPS_BROWSER_KEY=

# ADMIN_PANEL_PATH=/admindeoghar
# STATIC_HTML_CSP=1
